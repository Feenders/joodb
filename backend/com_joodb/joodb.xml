<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
	<name>JooDB</name>
	<creationDate>Jan 2009</creationDate>
	<author>Dirk Hoeschen, computer daten netze - feenders, joodb.feenders.de</author>
	<copyright>Copyright (C) 2009-2026 computer daten netze - feenders. All rights reserved.</copyright>
	<license>https://www.gnu.org/licenses/gpl-3.0.html GNU/GPL</license>
	<authorEmail>service@feenders.de</authorEmail>
	<authorUrl>https://joodb.feenders.de</authorUrl>
	<version>5.0.2</version>
	<description><![CDATA[
		JooDatabase is simple and fast way to include and display external tables (collections, databases) into Joomla.<br/>
		It automatically generates pages containing the table data using editable templates for catalog and single entry views.<br/>
		Special elements like print-icons and pagination-links are displayed at the desired position in the templates.<br/>
		JooDatabase handles the linking, routing between the pages automatically.
	]]></description>
	<namespace path="src">Feenders\Component\Joodb</namespace>
	<scriptfile>install.php</scriptfile>
	<files folder="frontend/com_joodb/">
		<folder>plugins</folder>
		<folder>src</folder>
		<folder>tmpl</folder>
	</files>
	<media folder="media/" destination="com_joodb">
		<folder>css</folder>
		<folder>fonts</folder>
		<folder>images</folder>
		<folder>js</folder>
		<folder>vendor</folder>
		<filename>index.html</filename>
		<filename>composer.json</filename>
		<filename>editor.php</filename>
		<filename>LICENSE_MIT</filename>
		<filename>LICENSE_CODEMIRROR2</filename>
		<filename>LICENSE_FONTELLO</filename>
	</media>
	<languages folder="frontend/language/">
		<language tag="en-GB">en-GB/com_joodb.ini</language>
		<language tag="de-DE">de-DE/com_joodb.ini</language>
		<language tag="nl-NL">nl-NL/com_joodb.ini</language>
		<language tag="fr-FR">fr-FR/com_joodb.ini</language>
	</languages>
	<administration>
		<menu view="joodb" img="class::database"  link="option=com_joodb">JooDB</menu>
		<submenu>
			<menu view="joodb" img="class::database" link="option=com_joodb&amp;view=joodb" alt="Joodb/Joodb">JDB_DATABASES</menu>
			<menu view="info" img="class::info" link="option=com_joodb&amp;view=info" alt="Joodb/Info">JDB_ABOUT</menu>
		</submenu>
		<files folder="backend/com_joodb">
			<filename>config_items.xml</filename>
			<filename>config.xml</filename>
			<filename>access.xml</filename>
			<filename>joodb.xml</filename>
			<filename>LICENSE</filename>
			<folder>assets</folder>
			<folder>forms</folder>
			<folder>services</folder>
			<folder>src</folder>
			<folder>tmpl</folder>
		</files>
		<languages folder="backend/language/">
			<language tag="en-GB">en-GB/com_joodb.ini</language>
			<language tag="en-GB">en-GB/com_joodb.sys.ini</language>
			<language tag="de-DE">de-DE/com_joodb.ini</language>
			<language tag="de-DE">de-DE/com_joodb.sys.ini</language>
			<language tag="nl-NL">nl-NL/com_joodb.ini</language>
			<language tag="nl-NL">nl-NL/com_joodb.sys.ini</language>
			<language tag="fr-FR">fr-FR/com_joodb.ini</language>
			<language tag="fr-FR">fr-FR/com_joodb.sys.ini</language>
		</languages>
	</administration>
	<updateservers>
		<server type="extension" priority="1" name="JooDatabase Updates"><![CDATA[https://joodb.feenders.de/update.html?version=5&format=xml]]></server>
	</updateservers>
</extension>
