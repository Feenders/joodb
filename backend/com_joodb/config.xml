<?xml version="1.0" encoding="utf-8"?>
<config>
	<fieldset
		name="general"
		label="JOODB_GLOBAL"
		description="COM_JOODB_SETTINGS_DESC">
		<field name="show_icons" type="radio"
               layout="joomla.form.field.radio.switcher"
               default="0" label="JDB_ICONS" description="JDB_SHOWICONS" class="btn-group btn-group-yesno">
			<option value="0">JHide</option>
			<option value="1">JShow</option>
		</field>
		<field name="internal_editor" type="radio"
               layout="joomla.form.field.radio.switcher"
               default="1" label="JDB_EDITOR" description="JDB_INTERNALEDITOR" class="btn-group btn-group-yesno">
			<option value="0">JDB_NO</option>
            <option value="1">JDB_YES</option>
		</field>
	</fieldset>
	<fieldset
		name="permissions"
		label="JCONFIG_PERMISSIONS_LABEL"
		description="JCONFIG_PERMISSIONS_DESC">

		<field
			name="rules"
			type="rules"
			label="JCONFIG_PERMISSIONS_LABEL"
			class="form-control"
			validate="rules"
			filter="rules"
			component="com_joodb"
			section="component" />
	</fieldset>
</config>
