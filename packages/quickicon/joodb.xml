<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="quickicon" method="update">
	<name>PLG_QUICKICON_JOODB</name>
	<author>Feenders.de</author>
	<creationDate>Oct 2021</creationDate>
	<copyright>Copyright (C) 2021-2026 All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<authorEmail>service@feenders.de</authorEmail>
	<authorUrl>www.feenders.de</authorUrl>
	<version>5.0</version>
	<description>PLG_QUICKICON_JOODB_XML_DESCRIPTION</description>
	<files>
		<filename plugin="joodb">joodb.php</filename>
		<folder>language</folder>
	</files>
	<languages folder="language/">
		<language tag="en-GB">en-GB/plg_quickicon_joodb.ini</language>
		<language tag="en-GB">en-GB/plg_quickicon_joodb.sys.ini</language>
		<language tag="de-DE">de-DE/plg_quickicon_joodb.ini</language>
		<language tag="de-DE">de-DE/plg_quickicon_joodb.sys.ini</language>
	</languages>	
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field name="context"
					type="text"
					default="mod_quickicon"
					description="PLG_QUICKICON_JOODB_GROUP_DESC"
					label="PLG_QUICKICON_JOODB_GROUP_LABEL"
				/>
			</fieldset>
		</fields>
	</config>
</extension>
